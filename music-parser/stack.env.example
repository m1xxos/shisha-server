# Music Parser – environment variables
# Copy this file to stack.env and adjust values before running.

# Traefik domain for the web UI
DOMAIN=music-parser.home.example.com

# Host path (or named volume) to mount as the music output directory.
# Files will be written here so Navidrome can pick them up.
MUSIC_DIR=/path/to/navidrome/music

# Output directory *inside* the container (usually leave as-is)
OUTPUT_DIR=/music
