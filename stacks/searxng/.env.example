# Copy to .env and fill in. .env is git-ignored.

# Public URL of the instance (used to build absolute links).
SEARXNG_BASE_URL=https://search.home.m1xxos.online/

# Secret key for the limiter and CSRF protection.
# Generate one with: openssl rand -hex 32
SEARXNG_SECRET=

# uWSGI tuning (defaults are fine for a homelab).
SEARXNG_UWSGI_WORKERS=4
SEARXNG_UWSGI_THREADS=4
